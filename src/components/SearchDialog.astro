<dialog class="search-dialog" aria-labelledby="search-dialog-title" data-search-dialog>
  <h2 id="search-dialog-title" class="sr-only">搜索教程</h2>
  <div class="search-head">
    <input class="search-input" type="search" placeholder="输入标题或正文关键词" aria-label="搜索教程" data-search-input />
    <button class="quiet-button" type="button" data-search-close>关闭</button>
  </div>
  <div class="search-status" aria-live="polite" data-search-status></div>
  <div class="search-results" data-search-results>
    <p class="search-empty">输入关键词，在 308 篇教程中查找。</p>
  </div>
</dialog>

<script>
  let searchItems = [];
  const dialog = document.querySelector('[data-search-dialog]');
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');
  const status = document.querySelector('[data-search-status]');
  let lastSearchTrigger = null;
  const escapeHtml = (value) => value.replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[char]);
  const excerpt = (item, query) => {
    const source = `${item.title} ${item.description}`.toLocaleLowerCase('zh-CN').includes(query) ? item.description : item.content;
    const position = source.toLocaleLowerCase('zh-CN').indexOf(query);
    if (position < 0) return source.slice(0, 90);
    const start = Math.max(0, position - 32);
    const end = Math.min(source.length, position + query.length + 55);
    return `${start ? '…' : ''}${source.slice(start, end)}${end < source.length ? '…' : ''}`;
  };

  document.querySelectorAll('[data-search-open]').forEach((button) => {
    button.addEventListener('click', async () => {
      lastSearchTrigger = button;
      dialog.showModal();
      requestAnimationFrame(() => input.focus());
      if (searchItems.length === 0) {
        status.textContent = '正在加载搜索索引…';
        try {
          const response = await fetch('/search-index.json');
          searchItems = await response.json();
          if (input.value.trim()) input.dispatchEvent(new Event('input'));
          else status.textContent = '';
        } catch {
          status.textContent = '';
          results.innerHTML = '<p class="search-empty">搜索索引加载失败，请刷新页面后重试。</p>';
        }
      }
    });
  });
  document.querySelector('[data-search-close]')?.addEventListener('click', () => dialog.close());
  dialog?.addEventListener('close', () => {
    if (lastSearchTrigger instanceof HTMLElement) lastSearchTrigger.focus();
  });
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) dialog.close();
  });
  input?.addEventListener('input', () => {
    const query = input.value.trim().toLocaleLowerCase('zh-CN');
    if (!query) {
      status.textContent = '';
      results.innerHTML = '<p class="search-empty">输入关键词，在 308 篇教程中查找。</p>';
      return;
    }
    const allMatches = searchItems
      .map((item) => {
        const title = item.title.toLocaleLowerCase('zh-CN');
        const chapter = item.chapterTitle.toLocaleLowerCase('zh-CN');
        const description = item.description.toLocaleLowerCase('zh-CN');
        const content = item.content.toLocaleLowerCase('zh-CN');
        const score = (title.includes(query) ? 8 : 0) + (title.startsWith(query) ? 4 : 0) + (chapter.includes(query) ? 3 : 0) + (description.includes(query) ? 2 : 0) + (content.includes(query) ? 1 : 0);
        return { ...item, score };
      })
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score);
    const matches = allMatches.slice(0, 24);
    status.textContent = allMatches.length ? `找到 ${allMatches.length} 篇相关教程${allMatches.length > 24 ? '，先显示 24 篇' : ''}` : '';
    results.innerHTML = matches.length
      ? matches.map((item) => `<a class="search-result" href="${item.href}"><small>${escapeHtml(item.chapterTitle)}</small><strong>${escapeHtml(item.title)}</strong><span>${escapeHtml(excerpt(item, query))}</span></a>`).join('')
      : '<p class="search-empty">没有找到相关教程，试试更短的关键词。</p>';
  });
</script>
