---
const { current = '', hasSidebar = false } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">M</span>
      <span>Mi姐交易笔记</span>
    </a>
    <nav class="header-nav" aria-label="主导航">
      <a href="/" aria-current={current === 'home' ? 'page' : undefined}>知识地图</a>
      <a href="/tutorial" aria-current={current === 'tutorial' ? 'page' : undefined}>全部教程</a>
    </nav>
    <div class="header-actions">
      <button class="command-trigger hide-mobile" type="button" data-search-open aria-label="搜索教程">
        <svg class="icon icon-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <span class="command-label">搜索教程…</span>
        <kbd class="kbd" data-kbd>⌘K</kbd>
      </button>
      <button class="icon-button mobile-only" type="button" data-search-open aria-label="搜索教程">
        <svg class="icon icon-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      <button class="icon-button" type="button" data-theme-toggle data-theme-state="light" aria-label="切换明暗主题">
        <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.5 14.2A8.5 8.5 0 1 1 9.8 3.5a6.8 6.8 0 0 0 10.7 10.7Z"></path></svg>
        <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><line x1="12" y1="2" x2="12" y2="4.5"></line><line x1="12" y1="19.5" x2="12" y2="22"></line><line x1="2" y1="12" x2="4.5" y2="12"></line><line x1="19.5" y1="12" x2="22" y2="12"></line><line x1="4.9" y1="4.9" x2="6.7" y2="6.7"></line><line x1="17.3" y1="17.3" x2="19.1" y2="19.1"></line><line x1="4.9" y1="19.1" x2="6.7" y2="17.3"></line><line x1="17.3" y1="6.7" x2="19.1" y2="4.9"></line></svg>
        <svg class="icon icon-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8"></circle><path d="M12 4a8 8 0 0 1 0 16Z" fill="currentColor" stroke="none"></path></svg>
      </button>
      {hasSidebar ? (
        <button class="quiet-button mobile-only" type="button" data-sidebar-open aria-label="打开章节导航">目录</button>
      ) : current === 'home' ? (
        <a class="quiet-button mobile-only" href="/tutorial">教程</a>
      ) : (
        <a class="quiet-button mobile-only" href="/">地图</a>
      )}
    </div>
  </div>
</header>

<script>
  const isMac = /\b(Mac|iPhone|iPad)\b/.test(navigator.platform) || (navigator.userAgentData && navigator.userAgentData.platform && /mac/i.test(navigator.userAgentData.platform));
  document.querySelectorAll('[data-kbd]').forEach((kbd) => { kbd.textContent = isMac ? '⌘K' : 'Ctrl K'; });
</script>
