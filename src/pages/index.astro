---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { chapters } from '../data/chapters';

const lessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);
const grouped = new Map(chapters.map((chapter) => [chapter.number, lessons.filter((lesson) => lesson.data.chapter === chapter.number)]));
const structuredLessons = lessons.filter((lesson) => /^#{2,4}\s/m.test(lesson.body)).length;
---

<BaseLayout current="home" lessons={lessons}>
  <main id="main-content">
    <section class="hero">
      <div class="hero-copy">
        <p class="hero-kicker">从认知到执行</p>
        <h1>把交易经验，整理成一条学习路径。</h1>
        <p class="hero-intro">308 篇中文短教程，帮你从基础认知走到独立判断。</p>
        <div class="hero-actions">
          <a class="primary-action" href="/tutorial/chapter-1/001" data-continue-link>开始第一课</a>
          <button class="secondary-action" type="button" data-search-open>搜索主题</button>
        </div>
      </div>
      <aside class="study-method" aria-label="学习方法">
        <p>一套可以持续的阅读方法</p>
        <ol>
          <li><span>01</span><div><strong>先看框架</strong><small>明确问题属于认知、工具还是执行。</small></div></li>
          <li><span>02</span><div><strong>每次解决一个问题</strong><small>短篇阅读，不用一次记住所有内容。</small></div></li>
          <li><span>03</span><div><strong>回到交易中验证</strong><small>标记已读，用复盘修正自己的判断。</small></div></li>
        </ol>
      </aside>
    </section>

    <dl class="course-facts" aria-label="课程统计">
      <div><dt>知识维度</dt><dd>6</dd></div>
      <div><dt>短教程</dt><dd>{lessons.length}</dd></div>
      <div><dt>已结构化文章</dt><dd>{structuredLessons}</dd></div>
      <div><dt>阅读方式</dt><dd class="fact-copy">顺序学习或按问题进入</dd></div>
    </dl>

    <section class="framework-section">
      <div class="framework-intro">
        <h2>六个维度，从市场认知走到交易行动。</h2>
        <a href="/tutorial">浏览全部教程 <span aria-hidden="true">→</span></a>
      </div>
      <div class="chapter-list">
        {chapters.map((chapter) => {
          const chapterLessons = grouped.get(chapter.number) ?? [];
          const first = chapterLessons[0];
          return (
            first && (
              <a class="chapter-row" href={`/tutorial/chapter-${chapter.number}`}>
                <span class="chapter-role">{chapter.role}</span>
                <span class="chapter-copy">
                  <small>第{chapter.numeral}章</small>
                  <strong>{chapter.title}</strong>
                  <span>{chapter.summary}</span>
                </span>
                <span class="chapter-meta"><b>{chapterLessons.length}</b> 篇</span>
                <span class="chapter-arrow" aria-hidden="true">↗</span>
              </a>
            )
          );
        })}
      </div>
    </section>

    <section class="closing-section">
      <div>
        <h2>先建立自己的判断，再做每一次交易。</h2>
      </div>
      <a href="/tutorial">查看完整目录 <span aria-hidden="true">→</span></a>
    </section>
  </main>
</BaseLayout>

<script>
  const lastLesson = localStorage.getItem('mjie-last-lesson');
  const continueLink = document.querySelector('[data-continue-link]');
  if (lastLesson && continueLink instanceof HTMLAnchorElement) {
    continueLink.href = `/tutorial/${lastLesson}`;
    continueLink.textContent = '继续上次阅读';
  }
</script>

<style>
  main { overflow: hidden; position: relative; }
  main::before { content: ''; position: absolute; z-index: -1; top: -220px; right: -180px; width: 640px; height: 640px; border-radius: 50%; background: radial-gradient(circle, color-mix(in srgb, var(--accent) 10%, transparent), transparent 68%); pointer-events: none; }
  .hero {
    width: min(1180px, calc(100% - 40px));
    min-height: calc(100dvh - var(--header-height));
    margin: 0 auto;
    padding: clamp(64px, 9vh, 96px) 0 72px;
    display: grid;
    grid-template-columns: minmax(0, 1.38fr) minmax(320px, .62fr);
    gap: clamp(70px, 10vw, 140px);
    align-items: center;
  }
  .hero-kicker { margin: 0 0 20px; color: var(--accent-strong); font-size: 14px; font-weight: 700; }
  h1 { margin: 0; max-width: 820px; font-size: clamp(48px, 6.1vw, 82px); line-height: 1.06; letter-spacing: -.055em; font-weight: 780; text-wrap: balance; }
  .hero-intro { max-width: 480px; margin: 26px 0 0; color: var(--text-soft); font-size: 17px; line-height: 1.75; text-wrap: pretty; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 32px; }
  .primary-action, .secondary-action {
    min-height: 46px;
    padding: 10px 19px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    white-space: nowrap;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: transform .2s ease, background .2s ease, border-color .2s ease;
  }
  .primary-action { border: 1px solid var(--accent); background: var(--accent); color: var(--accent-ink); }
  .secondary-action { border: 1px solid var(--line); background: var(--surface); color: var(--text); }
  .primary-action:hover, .secondary-action:hover { transform: translateY(-2px); }
  .primary-action:active, .secondary-action:active { transform: translateY(1px); }
  .secondary-action:hover { border-color: var(--accent); }
  .study-method { align-self: end; padding: 0 0 4px 28px; border-left: 1px solid var(--line); }
  .study-method > p { margin: 0 0 24px; color: var(--text-soft); font-size: 12px; }
  .study-method ol { margin: 0; padding: 0; display: grid; gap: 22px; list-style: none; }
  .study-method li { display: grid; grid-template-columns: 28px 1fr; gap: 12px; }
  .study-method li > span { padding-top: 2px; color: var(--accent-strong); font-family: var(--font-code); font-size: 10px; }
  .study-method li div { display: grid; gap: 3px; }
  .study-method strong { font-size: 14px; }
  .study-method small { color: var(--text-soft); font-size: 12px; line-height: 1.6; }
  .course-facts { width: min(1180px, calc(100% - 40px)); margin: 0 auto; padding: 30px 0 36px; display: grid; grid-template-columns: .7fr .7fr .9fr 1.7fr; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .course-facts div { padding: 0 24px; border-left: 1px solid var(--line); }
  .course-facts div:first-child { padding-left: 0; border-left: 0; }
  .course-facts dt { color: var(--text-soft); font-size: 11px; }
  .course-facts dd { margin: 3px 0 0; font-family: var(--font-code); font-size: 26px; font-weight: 760; font-variant-numeric: tabular-nums; }
  .course-facts .fact-copy { padding-top: 4px; font-family: inherit; font-size: 14px; font-weight: 650; }
  .framework-section { width: min(1180px, calc(100% - 40px)); margin: 0 auto; padding: 140px 0 150px; display: grid; grid-template-columns: minmax(260px, .7fr) minmax(0, 1.3fr); gap: clamp(70px, 10vw, 150px); align-items: start; }
  .framework-intro { position: sticky; top: 110px; }
  .framework-intro h2, .closing-section h2 { margin: 0; font-size: clamp(34px, 4vw, 52px); line-height: 1.16; letter-spacing: -.04em; text-wrap: balance; }
  .framework-intro > a { display: inline-flex; align-items: center; gap: 8px; margin-top: 28px; color: var(--accent-strong); font-size: 13px; font-weight: 700; }
  .framework-intro > a span, .closing-section > a span { transition: transform .2s ease; }
  .framework-intro > a:hover span, .closing-section > a:hover span { transform: translateX(4px); }
  .chapter-list { display: grid; }
  .chapter-row { min-height: 174px; display: grid; grid-template-columns: 54px minmax(0, 1fr) auto 20px; gap: 20px; align-items: center; padding: 28px 0; border-bottom: 1px solid var(--line); transition: color .2s ease, transform .2s ease; }
  .chapter-row:first-child { border-top: 1px solid var(--line); }
  .chapter-row:nth-child(even) { margin-left: clamp(0px, 3vw, 42px); }
  .chapter-row:hover { color: var(--accent-strong); transform: translateX(5px); }
  .chapter-role { color: var(--accent-strong); font-size: 38px; font-weight: 780; line-height: 1; }
  .chapter-copy { min-width: 0; display: grid; }
  .chapter-copy small { color: var(--text-soft); font-size: 10px; }
  .chapter-copy strong { margin-top: 2px; font-size: 23px; letter-spacing: -.025em; }
  .chapter-copy > span { max-width: 48ch; margin-top: 7px; color: var(--text-soft); font-size: 13px; line-height: 1.65; }
  .chapter-meta { color: var(--text-soft); white-space: nowrap; font-size: 11px; }
  .chapter-meta b { color: var(--text); font-family: var(--font-code); font-size: 16px; font-variant-numeric: tabular-nums; }
  .chapter-arrow { color: var(--text-soft); }
  .closing-section { width: min(1180px, calc(100% - 40px)); margin: 0 auto 120px; padding: 72px 0 8px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 50px; align-items: end; border-top: 1px solid var(--line); }
  .closing-section h2 { max-width: 760px; }
  .closing-section > a { display: inline-flex; align-items: center; gap: 8px; padding-bottom: 10px; color: var(--accent-strong); white-space: nowrap; font-size: 14px; font-weight: 700; }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; padding-top: 72px; gap: 72px; }
    .study-method { max-width: 620px; }
    .framework-section { grid-template-columns: 1fr; gap: 54px; }
    .framework-intro { position: static; max-width: 680px; }
  }
  @media (max-width: 700px) {
    .hero, .course-facts, .framework-section, .closing-section { width: calc(100% - 28px); }
    .hero { padding: 58px 0 68px; gap: 58px; }
    h1 { font-size: clamp(43px, 12.5vw, 56px); line-height: 1.08; }
    .hero-intro { font-size: 15px; }
    .study-method { padding-left: 18px; }
    .course-facts { grid-template-columns: 1fr 1fr; padding: 0; }
    .course-facts div { min-height: 102px; padding: 18px 14px; border-bottom: 1px solid var(--line); }
    .course-facts div:nth-child(odd) { border-left: 0; }
    .course-facts div:first-child { padding-left: 14px; }
    .course-facts div:nth-last-child(-n + 2) { border-bottom: 0; }
    .course-facts dd { font-size: 22px; }
    .course-facts .fact-copy { max-width: 12ch; font-size: 12px; }
    .framework-section { padding: 96px 0 108px; }
    .framework-intro h2, .closing-section h2 { font-size: 36px; }
    .chapter-row, .chapter-row:nth-child(even) { min-height: 154px; margin-left: 0; grid-template-columns: 42px minmax(0, 1fr) 18px; gap: 14px; }
    .chapter-role { font-size: 30px; }
    .chapter-copy strong { font-size: 20px; }
    .chapter-copy > span { font-size: 12px; }
    .chapter-meta { grid-column: 2; margin-top: -8px; }
    .chapter-arrow { grid-column: 3; grid-row: 1; }
    .closing-section { margin-bottom: 90px; padding-top: 58px; grid-template-columns: 1fr; align-items: start; }
  }
</style>
