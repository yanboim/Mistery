---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { chapters } from '../data/chapters';

const lessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);
const grouped = new Map(chapters.map((chapter) => [chapter.number, lessons.filter((lesson) => lesson.data.chapter === chapter.number)]));
---

<BaseLayout current="home" lessons={lessons}>
  <main id="main-content">
    <section class="hero">
      <div class="hero-copy">
        <p class="hero-kicker">从认知到执行的交易学习地图</p>
        <h1>把零散经验，整理成一条可学习的路径。</h1>
        <p class="hero-intro">6 个知识维度，308 篇短教程。按章节循序学习，也可以从当前问题直接进入。</p>
        <div class="hero-actions">
          <a class="primary-action" href="/tutorial/chapter-1/001" data-continue-link>开始第一课</a>
          <button class="secondary-action" type="button" data-search-open>搜索主题</button>
        </div>
        <dl class="hero-stats" aria-label="教程统计">
          <div><dt>章节</dt><dd>6</dd></div>
          <div><dt>教程</dt><dd>{lessons.length}</dd></div>
          <div><dt>阅读方式</dt><dd>按需或顺序</dd></div>
        </dl>
      </div>

      <div class="map-shell" aria-label="知识地图">
        <div class="map-axis">
          <span>市场认知</span>
          <i></i>
          <span>交易行动</span>
        </div>
        <div class="map-grid">
          {chapters.map((chapter, index) => {
            const chapterLessons = grouped.get(chapter.number) ?? [];
            return (
              <a class="map-node" style={`--delay:${index * 70}ms`} href={`/tutorial#chapter-${chapter.number}`}>
                <span class="node-role">{chapter.role}</span>
                <span class="node-copy">
                  <strong>{chapter.title}</strong>
                  <small>{chapterLessons.length} 篇教程</small>
                </span>
                <span class="node-arrow" aria-hidden="true">↗</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="chapter-section">
      <div class="section-heading">
        <h2>六个维度，一套完整框架</h2>
        <p>先建立基础认知，再学习工具与策略，最后把视野扩展到宏观周期和长期心法。</p>
      </div>
      <div class="chapter-grid">
        {chapters.map((chapter) => {
          const chapterLessons = grouped.get(chapter.number) ?? [];
          const first = chapterLessons[0];
          return (
            <article class="chapter-card">
              <div class="chapter-topline">
                <span>第{chapter.numeral}章</span>
                <span>{chapterLessons.length} 节</span>
              </div>
              <h3><span>{chapter.role}</span>{chapter.title}</h3>
              <p>{chapter.summary}</p>
              {first && <a href={`/tutorial/${first.id}`}>进入本章 <span aria-hidden="true">→</span></a>}
            </article>
          );
        })}
      </div>
    </section>

    <section class="reading-path">
      <div>
        <h2>不知道从哪里开始？</h2>
        <p>从基础认知进入，按页面底部的下一篇持续阅读。每篇只解决一个主题。</p>
      </div>
      <a class="primary-action" href="/tutorial/chapter-1/001">进入学习路径</a>
    </section>
  </main>
</BaseLayout>

<script>
  const lastLesson = localStorage.getItem('mjie-last-lesson');
  const continueLink = document.querySelector('[data-continue-link]');
  if (lastLesson && continueLink instanceof HTMLAnchorElement) {
    continueLink.href = `/tutorial/${lastLesson}`;
    continueLink.textContent = '继续上次阅读';
  }
</script>

<style>
  main { overflow: hidden; }
  .hero {
    width: min(1180px, calc(100% - 40px));
    min-height: calc(100dvh - var(--header-height));
    margin: 0 auto;
    padding: 70px 0 56px;
    display: grid;
    grid-template-columns: minmax(0, .88fr) minmax(460px, 1.12fr);
    gap: clamp(54px, 8vw, 112px);
    align-items: center;
  }
  .hero-kicker { margin: 0 0 20px; color: var(--accent-strong); font-size: 13px; font-weight: 700; letter-spacing: .12em; }
  h1 { margin: 0; max-width: 720px; font-size: clamp(40px, 5vw, 68px); line-height: 1.12; letter-spacing: -.045em; font-weight: 780; }
  .hero-intro { max-width: 520px; margin: 24px 0 0; color: var(--text-soft); font-size: 17px; line-height: 1.8; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 32px; }
  .primary-action, .secondary-action {
    min-height: 46px;
    padding: 10px 19px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    white-space: nowrap;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: transform .2s ease, background .2s ease, border-color .2s ease;
  }
  .primary-action { border: 1px solid var(--accent); background: var(--accent); color: var(--accent-ink); }
  .secondary-action { border: 1px solid var(--line); background: var(--surface); color: var(--text); }
  .primary-action:hover, .secondary-action:hover { transform: translateY(-2px); }
  .secondary-action:hover { border-color: var(--accent); }
  .hero-stats { display: flex; gap: 30px; margin: 42px 0 0; }
  .hero-stats div { display: flex; flex-direction: column-reverse; gap: 2px; }
  .hero-stats dt { color: var(--text-soft); font-size: 12px; }
  .hero-stats dd { margin: 0; font-family: ui-monospace, monospace; font-weight: 750; font-size: 16px; }
  .map-shell { position: relative; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 20px; box-shadow: var(--shadow); }
  .map-shell::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px); background-size: 28px 28px; opacity: .23; pointer-events: none; }
  .map-axis { position: relative; display: flex; align-items: center; gap: 12px; color: var(--text-soft); font-size: 11px; margin: 2px 4px 16px; }
  .map-axis i { height: 1px; flex: 1; background: var(--line); }
  .map-grid { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .map-node { min-height: 112px; display: grid; grid-template-columns: 42px 1fr auto; align-items: center; gap: 12px; padding: 16px; border: 1px solid var(--line); border-radius: 9px; background: color-mix(in srgb, var(--surface-raised) 94%, transparent); transition: transform .25s ease, border-color .25s ease; animation: map-in .6s both; animation-delay: var(--delay); }
  .map-node:nth-child(2), .map-node:nth-child(5) { transform: translateY(12px); }
  .map-node:hover { transform: translateY(-3px); border-color: var(--accent); }
  .map-node:nth-child(2):hover, .map-node:nth-child(5):hover { transform: translateY(9px); }
  .node-role { width: 38px; height: 38px; display: grid; place-items: center; border: 1px solid var(--accent); border-radius: 50%; color: var(--accent-strong); font-size: 18px; font-weight: 800; }
  .node-copy { display: flex; flex-direction: column; min-width: 0; }
  .node-copy strong { font-size: 14px; }
  .node-copy small { color: var(--text-soft); font-size: 11px; }
  .node-arrow { color: var(--text-soft); }
  .chapter-section { width: min(1180px, calc(100% - 40px)); margin: 0 auto; padding: 110px 0 130px; }
  .section-heading { max-width: 620px; margin-bottom: 46px; }
  .section-heading h2, .reading-path h2 { margin: 0; font-size: clamp(30px, 4vw, 48px); line-height: 1.18; letter-spacing: -.035em; }
  .section-heading p, .reading-path p { color: var(--text-soft); margin: 16px 0 0; max-width: 580px; }
  .chapter-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 14px; }
  .chapter-card { grid-column: span 4; min-height: 300px; display: flex; flex-direction: column; padding: 26px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
  .chapter-card:nth-child(1), .chapter-card:nth-child(6) { grid-column: span 5; }
  .chapter-card:nth-child(2), .chapter-card:nth-child(5) { grid-column: span 7; }
  .chapter-topline { display: flex; justify-content: space-between; color: var(--text-soft); font-size: 12px; }
  .chapter-card h3 { display: flex; align-items: center; gap: 13px; margin: 34px 0 14px; font-size: 23px; letter-spacing: -.02em; }
  .chapter-card h3 span { color: var(--accent-strong); font-size: 34px; }
  .chapter-card p { margin: 0; color: var(--text-soft); max-width: 48ch; }
  .chapter-card a { margin-top: auto; padding-top: 28px; color: var(--accent-strong); font-size: 14px; font-weight: 700; }
  .chapter-card a span { display: inline-block; transition: transform .2s ease; }
  .chapter-card a:hover span { transform: translateX(4px); }
  .reading-path { width: min(1180px, calc(100% - 40px)); margin: 0 auto 110px; padding: 54px; display: flex; align-items: center; justify-content: space-between; gap: 40px; border: 1px solid var(--accent); border-radius: var(--radius); background: var(--surface-raised); }
  @keyframes map-in { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; } }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding-top: 48px; gap: 52px; }
    .map-shell { max-width: 720px; }
  }
  @media (max-width: 700px) {
    .hero, .chapter-section, .reading-path { width: calc(100% - 28px); }
    .hero { padding: 42px 0 64px; }
    h1 { font-size: clamp(38px, 12vw, 54px); }
    .hero-stats { gap: 18px; justify-content: space-between; }
    .map-shell { display: none; }
    .map-node:nth-child(2), .map-node:nth-child(5) { transform: none; }
    .map-node:nth-child(2):hover, .map-node:nth-child(5):hover { transform: translateY(-3px); }
    .chapter-section { padding: 76px 0 90px; }
    .chapter-card, .chapter-card:nth-child(1), .chapter-card:nth-child(2), .chapter-card:nth-child(5), .chapter-card:nth-child(6) { grid-column: 1 / -1; min-height: 270px; }
    .reading-path { padding: 30px 24px; flex-direction: column; align-items: flex-start; }
  }
  @media (prefers-reduced-motion: reduce) { .map-node { animation: none; } }
</style>
