---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { chapters } from '../../data/chapters';
import { siteConfig, withSiteTitle } from '../../site.config';
import { getLessonStableId, getLessonURL } from '../../utils/lesson-url';

const lessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);
const visibleChapters = chapters.filter((chapter) => lessons.some((lesson) => lesson.data.chapter === chapter.number));
const copy = siteConfig.copy.tutorial;
const pageDescription = copy.description.replace('{siteName}', siteConfig.name);
const firstLesson = lessons[0];
---

<BaseLayout title={withSiteTitle(copy.title)} description={pageDescription} current="tutorial" lessons={lessons}>
  <main
    class="catalog"
    id="main-content"
    data-catalog-copy
    data-filter-status-all={copy.filter.statusAll}
    data-filter-status-matched={copy.filter.statusMatched}
    data-filter-read={copy.filter.read}
    data-filter-unread={copy.filter.unread}
    data-chapter-read-template={copy.chapter.readTemplate}
    data-chapter-collapse={copy.chapter.collapse}
    data-chapter-expand={copy.chapter.expand}
    data-progress-complete-template={copy.overview.completeTemplate}
  >
    <header class="catalog-head">
      <p>{copy.kicker}</p>
      <h1>{copy.titleLines[0]}<br />{copy.titleLines[1]}</h1>
    </header>
    <section class="learning-overview" data-learning-overview hidden aria-label={copy.overview.label}>
      <div class="overview-copy">
        <span>{copy.overview.record}</span>
        <strong><b data-completed-count>0</b> / {lessons.length}</strong>
        <small data-progress-copy>{copy.overview.completeTemplate.replace('{percent}', '0')}</small>
      </div>
      <div class="overview-progress" aria-hidden="true"><i data-progress-bar></i></div>
      <a href={firstLesson ? getLessonURL(firstLesson) : '/tutorial'} data-resume-link>{copy.overview.resume} <span aria-hidden="true">→</span></a>
    </section>
    <div class="catalog-sticky-controls">
      <div class="catalog-filter">
        <span>{copy.filter.label}</span>
        <div class="progress-filter" role="group" aria-label="按学习状态筛选">
          <button type="button" aria-pressed="true" data-progress-filter="all">{copy.filter.all}</button>
          <button type="button" aria-pressed="false" data-progress-filter="unread">{copy.filter.unread}</button>
          <button type="button" aria-pressed="false" data-progress-filter="read">{copy.filter.read}</button>
        </div>
        <p aria-live="polite" data-filter-status>{copy.filter.statusAll.replace('{count}', String(lessons.length))}</p>
      </div>
      <nav class="chapter-jump" aria-label={copy.chapterJumpLabel}>
        {visibleChapters.map((chapter) => (
          <a href={`#chapter-${chapter.number}`}>
            <span>{chapter.role}</span>
            {chapter.title}
            <small data-chapter-jump-progress={chapter.number}>0%</small>
          </a>
        ))}
      </nav>
    </div>
    <p class="catalog-empty" hidden data-catalog-empty>{copy.empty}</p>
    <div class="chapter-list">
      {visibleChapters.map((chapter) => {
        const items = lessons.filter((lesson) => lesson.data.chapter === chapter.number);
        return (
          <section id={`chapter-${chapter.number}`} class="catalog-chapter" data-catalog-chapter>
            <header>
              <span class="role">{chapter.role}</span>
              <div>
                <small>{copy.chapter.prefix}{chapter.numeral}{copy.chapter.separator}<span class="chapter-read-count" data-chapter-progress={chapter.number} data-chapter-total={items.length}>{copy.chapter.readTemplate.replace('{read}', '0').replace('{total}', String(items.length))}</span></small>
                <h2>{chapter.title}</h2>
                <p>{chapter.summary}</p>
                <div class="chapter-progress-line" aria-hidden="true"><i data-chapter-progress-bar={chapter.number}></i></div>
                <a class="chapter-page-link" href={`/tutorial/chapter-${chapter.number}`}>{copy.chapter.enter} <span aria-hidden="true">→</span></a>
              </div>
              <button class="chapter-toggle" type="button" aria-expanded="true" aria-controls={`chapter-lessons-${chapter.number}`} data-chapter-toggle>{copy.chapter.collapse}</button>
            </header>
            <ol id={`chapter-lessons-${chapter.number}`}>
              {items.map((lesson) => (
                <li>
                  <a href={getLessonURL(lesson)} data-lesson-link={getLessonStableId(lesson)} data-lesson-url={getLessonURL(lesson)} data-chapter-number={chapter.number}>
                    <span>{String(lesson.data.chapterOrder).padStart(2, '0')}</span>
                    <strong>{lesson.data.title}</strong>
                    <i aria-hidden="true">→</i>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        );
      })}
    </div>
  </main>
</BaseLayout>

<script>
  const catalogRoot = document.querySelector('[data-catalog-copy]');
  const copy = catalogRoot?.dataset || {};
  const formatCopy = (template, values) => Object.entries(values).reduce((text, [key, value]) => text.replaceAll(`{${key}}`, String(value)), template || '');
  const mobileCatalog = window.matchMedia('(max-width: 800px)');
  const sections = [...document.querySelectorAll('[data-catalog-chapter]')];
  const setSection = (section, expanded) => {
    const button = section.querySelector('[data-chapter-toggle]');
    const list = section.querySelector('ol');
    if (!button || !list) return;
    button.setAttribute('aria-expanded', String(expanded));
    button.textContent = expanded ? copy.chapterCollapse || '收起' : copy.chapterExpand || '展开';
    list.hidden = !expanded;
  };
  const syncCatalog = () => {
    if (!mobileCatalog.matches) return sections.forEach((section) => setSection(section, true));
    const target = document.querySelector(location.hash || '#chapter-1');
    sections.forEach((section) => setSection(section, section === target));
  };
  sections.forEach((section) => section.querySelector('[data-chapter-toggle]')?.addEventListener('click', () => {
    const button = section.querySelector('[data-chapter-toggle]');
    setSection(section, button?.getAttribute('aria-expanded') !== 'true');
  }));
  document.querySelectorAll('.chapter-jump a').forEach((link) => link.addEventListener('click', () => {
    if (!mobileCatalog.matches) return;
    const target = document.querySelector(link.getAttribute('href'));
    if (target) setSection(target, true);
  }));
  mobileCatalog.addEventListener('change', syncCatalog);
  syncCatalog();

  const filterStatus = document.querySelector('[data-filter-status]');
  const emptyState = document.querySelector('[data-catalog-empty]');
  const progressButtons = [...document.querySelectorAll('[data-progress-filter]')];
  const lessonLinks = [...document.querySelectorAll('[data-lesson-link]')];
  let activeProgressFilter = 'all';
  let completedSet = new Set();

  const updateChapterProgress = () => {
    document.querySelectorAll('[data-chapter-progress]').forEach((element) => {
      const chapter = element.getAttribute('data-chapter-progress');
      const total = Number(element.getAttribute('data-chapter-total') || 0);
      const completed = lessonLinks.filter((link) => link.getAttribute('data-chapter-number') === chapter && completedSet.has(link.getAttribute('data-lesson-link'))).length;
      const percentage = total ? Math.round((completed / total) * 100) : 0;
      element.textContent = formatCopy(copy.chapterReadTemplate || '{read} / {total} 已读', { read: completed, total });
      document.querySelector(`[data-chapter-progress-bar="${CSS.escape(chapter)}"]`)?.style.setProperty('--chapter-completion', `${percentage}%`);
      document.querySelector(`[data-chapter-jump-progress="${CSS.escape(chapter)}"]`).textContent = `${percentage}%`;
    });
  };

  const updateProgressButtons = () => {
    progressButtons.forEach((button) => {
      button.setAttribute('aria-pressed', String(button.getAttribute('data-progress-filter') === activeProgressFilter));
    });
  };

  const applyFilter = () => {
    let visible = 0;
    lessonLinks.forEach((link) => {
      const lessonId = link.getAttribute('data-lesson-link');
      const isCompleted = completedSet.has(lessonId);
      const matched = activeProgressFilter === 'all' || (activeProgressFilter === 'read' ? isCompleted : !isCompleted);
      link.closest('li').hidden = !matched;
      if (matched) visible += 1;
    });
    sections.forEach((section) => {
      const count = section.querySelectorAll('li:not([hidden])').length;
      section.hidden = activeProgressFilter !== 'all' && count === 0;
      if (activeProgressFilter !== 'all' && count) setSection(section, true);
    });
    if (activeProgressFilter === 'all') syncCatalog();
    if (emptyState) emptyState.hidden = visible > 0;
    const filterName = activeProgressFilter === 'read' ? copy.filterRead || '已读' : activeProgressFilter === 'unread' ? copy.filterUnread || '未读' : '';
    if (filterStatus) {
      filterStatus.textContent = filterName
        ? formatCopy(copy.filterStatusMatched || '找到 {count} 篇 {filter}教程', { count: visible, filter: filterName })
        : formatCopy(copy.filterStatusAll || '共 {count} 篇教程', { count: lessonLinks.length });
    }
  };
  progressButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeProgressFilter = button.getAttribute('data-progress-filter') || 'all';
      updateProgressButtons();
      applyFilter();
    });
  });

  try {
    const completed = JSON.parse(localStorage.getItem('mjie-completed-lessons') || '[]');
    completedSet = new Set(completed);
    completed.forEach((id) => document.querySelector(`[data-lesson-link="${CSS.escape(id)}"]`)?.classList.add('completed'));
    updateChapterProgress();
    const overview = document.querySelector('[data-learning-overview]');
    if (completed.length && overview) {
      const percentage = Math.round((completed.length / lessonLinks.length) * 100);
      overview.querySelector('[data-completed-count]').textContent = String(completed.length);
      overview.querySelector('[data-progress-copy]').textContent = formatCopy(copy.progressCompleteTemplate || '已完成 {percent}%', { percent: percentage });
      overview.querySelector('[data-progress-bar]').style.width = `${percentage}%`;
      const resume = overview.querySelector('[data-resume-link]');
      const lastLesson = localStorage.getItem('mjie-last-lesson');
      const lastLessonLink = lastLesson && document.querySelector(`[data-lesson-link="${CSS.escape(lastLesson)}"]`);
      if (resume instanceof HTMLAnchorElement && lastLessonLink instanceof HTMLAnchorElement) {
        resume.href = lastLessonLink.href;
      }
      overview.hidden = false;
    }
  } catch {}
  updateProgressButtons();
  applyFilter();
</script>

<style>
  .catalog { --catalog-sticky-height: 226px; position: relative; width: min(1180px, calc(100% - 40px)); margin: 0 auto; padding: 58px 0 130px; overflow: visible; }
  .catalog::before { content: ''; position: absolute; z-index: -1; top: -210px; right: -220px; width: 620px; height: 620px; border-radius: 50%; background: radial-gradient(circle, color-mix(in srgb, var(--accent) 9%, transparent), transparent 68%); pointer-events: none; }
  .catalog-head { min-height: 300px; display: grid; align-items: end; gap: 96px; margin-bottom: 44px; padding-bottom: 42px; border-bottom: 1px solid var(--line); }
  .catalog-head > p { margin: 0; color: var(--accent-strong); font-size: 14px; font-weight: 700; }
  .catalog-head h1 { max-width: 1050px; margin: 0; font-size: clamp(44px, 5.6vw, 72px); line-height: 1.08; letter-spacing: -.055em; text-wrap: balance; }
  .learning-overview { margin: -28px 0 70px; padding: 24px 26px; display: grid; grid-template-columns: auto minmax(160px, 1fr) auto; align-items: center; gap: 24px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--surface) 78%, transparent); }
  .learning-overview[hidden] { display: none; }
  .overview-copy { display: grid; grid-template-columns: auto auto; align-items: baseline; gap: 2px 14px; }
  .overview-copy span { grid-column: 1 / -1; color: var(--text-soft); font-size: 11px; }
  .overview-copy strong { font-family: var(--font-code); font-size: 18px; font-variant-numeric: tabular-nums; }
  .overview-copy b { color: var(--accent-strong); }
  .overview-copy small { color: var(--text-soft); }
  .overview-progress { height: 5px; overflow: hidden; border-radius: 2px; background: var(--line); }
  .overview-progress i { width: 0; height: 100%; display: block; background: var(--accent); transition: width .35s ease; }
  .learning-overview > a { color: var(--accent-strong); font-size: 13px; font-weight: 700; }
  .learning-overview > a span { display: inline-block; transition: transform .2s ease; }
  .learning-overview > a:hover span { transform: translateX(3px); }
  .catalog-sticky-controls { position: sticky; z-index: 24; top: var(--header-height); margin: 0 0 96px; padding: 24px 0 38px; background: color-mix(in srgb, var(--bg) 94%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--line) 84%, transparent); backdrop-filter: blur(18px); }
  .catalog-sticky-controls::before { content: ''; position: absolute; z-index: -1; inset: 0 -20px; background: color-mix(in srgb, var(--bg) 94%, transparent); }
  .catalog-filter { margin-bottom: 30px; padding-bottom: 26px; display: flex; align-items: center; justify-content: space-between; gap: 16px; border-bottom: 1px solid var(--line); }
  .catalog-filter > span { color: var(--text-soft); font-size: 12px; font-weight: 700; }
  .catalog-filter button { min-height: 46px; padding: 8px 13px; border: 1px solid var(--line); border-radius: 8px; background: transparent; cursor: pointer; transition: border-color .2s ease, color .2s ease, transform .2s ease; }
  .catalog-filter button:hover { border-color: var(--accent); color: var(--accent-strong); }
  .catalog-filter button:active { transform: translateY(1px); }
  .catalog-filter .progress-filter { display: inline-flex; width: max-content; max-width: 100%; gap: 1px; padding: 3px; border: 1px solid var(--line); border-radius: 9px; background: var(--surface); }
  .progress-filter button { min-height: 34px; padding: 6px 12px; border: 0; border-radius: 6px; color: var(--text-soft); font-size: 12px; }
  .progress-filter button[aria-pressed='true'] { background: var(--accent); color: var(--accent-ink); }
  .catalog-filter p { margin: 0 0 0 auto; color: var(--text-soft); font-size: 11px; }
  .catalog-empty { margin: -12px 0 44px; padding: 22px 24px; border: 1px solid var(--line); background: var(--surface); color: var(--text-soft); font-size: 14px; }
  .catalog-empty[hidden] { display: none; }
  .chapter-jump { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 1px; margin: 0; border: 1px solid var(--line); background: var(--line); }
  .chapter-jump a { min-height: 86px; display: grid; align-content: center; gap: 3px; padding: 13px 14px; background: var(--bg); color: var(--text-soft); font-size: 12px; transition: background .2s ease, color .2s ease; }
  .chapter-jump a:hover { background: var(--surface); color: var(--text); }
  .chapter-jump span { color: var(--accent-strong); font-weight: 800; }
  .chapter-jump small { color: var(--text-soft); font-family: var(--font-code); font-size: 10px; font-variant-numeric: tabular-nums; }
  .chapter-list { display: grid; gap: 118px; }
  .catalog-chapter { scroll-margin-top: calc(var(--header-height) + var(--catalog-sticky-height) + 28px); display: grid; grid-template-columns: minmax(250px, .66fr) minmax(0, 1.34fr); gap: clamp(44px, 8vw, 118px); align-items: start; }
  .catalog-chapter > header { align-self: start; position: sticky; top: calc(var(--header-height) + var(--catalog-sticky-height) + 28px); display: grid; grid-template-columns: 58px 1fr auto; gap: 18px; padding-top: 4px; }
  .role { width: 52px; height: 52px; display: grid; place-items: center; border-bottom: 1px solid var(--accent); color: var(--accent-strong); font-size: 34px; line-height: 1; font-weight: 800; }
  .catalog-chapter small { color: var(--text-soft); }
  .chapter-read-count { font-variant-numeric: tabular-nums; }
  .catalog-chapter h2 { margin: 3px 0 10px; font-size: clamp(28px, 3vw, 38px); line-height: 1.16; letter-spacing: -.035em; text-wrap: balance; }
  .catalog-chapter header p { max-width: 30ch; margin: 0; color: var(--text-soft); font-size: 14px; line-height: 1.75; }
  .chapter-progress-line { width: min(210px, 100%); height: 4px; margin-top: 18px; overflow: hidden; border-radius: 999px; background: var(--line); }
  .chapter-progress-line i { display: block; width: var(--chapter-completion, 0%); height: 100%; border-radius: inherit; background: var(--accent); transition: width .35s ease; }
  .chapter-page-link { width: fit-content; margin-top: 14px; display: inline-flex; color: var(--accent-strong); font-size: 12px; font-weight: 700; border-bottom: 1px solid currentColor; }
  ol { margin: 0; padding: 0; list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-content: start; border: 1px solid var(--line); border-right: 0; border-bottom: 0; background: transparent; }
  ol[hidden] { display: none; }
  li a { min-height: 92px; display: grid; grid-template-columns: 32px 1fr auto; gap: 12px; align-items: center; padding: 16px 17px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg); transition: background .2s ease, color .2s ease, transform .2s ease; }
  li a:hover { background: var(--surface); color: var(--accent-strong); transform: translateX(3px); }
  li a.completed { background: color-mix(in srgb, var(--surface) 76%, var(--accent) 8%); }
  li a.completed::after { content: '已读'; position: absolute; top: 8px; right: 10px; color: var(--accent-strong); font-size: 9px; }
  li a { position: relative; }
  li span { color: var(--text-soft); font-family: var(--font-code); font-size: 11px; }
  li strong { font-size: 14px; line-height: 1.5; text-wrap: pretty; }
  li i { color: var(--text-soft); font-style: normal; }
  .chapter-toggle { display: none; }
  @media (min-width: 801px) {
    .catalog-chapter { min-height: calc(100dvh - var(--header-height)); }
  }
  @media (max-width: 800px) {
    .catalog { --catalog-sticky-height: 188px; width: calc(100% - 28px); padding-top: 44px; }
    .catalog-head { min-height: auto; gap: 56px; margin-bottom: 34px; padding-bottom: 32px; }
    .catalog-head h1 { font-size: clamp(36px, 9.6vw, 42px); line-height: 1.12; letter-spacing: -.045em; }
    .learning-overview { margin: 0 0 44px; grid-template-columns: 1fr auto; gap: 16px; }
    .overview-progress { grid-column: 1 / -1; grid-row: 2; }
    .learning-overview > a { grid-column: 2; grid-row: 1; }
    .catalog-sticky-controls { top: var(--header-height); margin: 0 0 58px; padding: 18px 0 20px; }
    .catalog-filter { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 18px; padding-bottom: 18px; }
    .catalog-filter .progress-filter { width: 100%; }
    .progress-filter button { flex: 1; }
    .catalog-filter p { margin: -4px 0 0; }
    .chapter-jump { flex-wrap: nowrap; overflow-x: auto; margin: 0 -14px; padding: 0 14px 8px; scrollbar-width: none; }
    .chapter-jump { display: flex; border: 0; background: transparent; }
    .chapter-jump a { flex: 0 0 auto; min-height: 58px; border: 1px solid var(--line); }
    .catalog-chapter { min-height: auto; scroll-margin-top: calc(var(--header-height) + 176px); grid-template-columns: 1fr; gap: 28px; }
    .catalog-chapter > header { position: static; grid-template-columns: 48px 1fr auto; padding-top: 0; }
    .role { width: 42px; height: 42px; font-size: 28px; }
    .chapter-toggle { display: inline-flex; align-items: center; justify-content: center; min-width: 52px; min-height: 44px; padding: 7px 10px; border: 1px solid var(--line); border-radius: 7px; background: var(--surface); color: var(--text-soft); font-size: 12px; cursor: pointer; }
    ol { grid-template-columns: 1fr; max-height: none; overflow: visible; }
  }
</style>
