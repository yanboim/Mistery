---
import Header from '../components/Header.astro';
import SearchDialog from '../components/SearchDialog.astro';
import { getCanonicalSiteURL, siteConfig } from '../site.config';
import 'heti/umd/heti.min.css';
import '../styles/global.css';

const {
  title = siteConfig.name,
  description = siteConfig.description,
  current = '',
  lessons = [],
  hasSidebar = false,
  schemaType = 'WebPage',
} = Astro.props;
const siteURL = Astro.site ?? getCanonicalSiteURL();
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(siteConfig.ogImage, siteURL);
const toFontStack = (fonts: string[]) => fonts.join(', ');
const fontVariables = `
  :root {
    --font-body: ${toFontStack(siteConfig.fonts.body)};
    --font-heading: ${toFontStack(siteConfig.fonts.heading)};
    --font-code: ${toFontStack(siteConfig.fonts.code)};
  }
`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: title,
  headline: title,
  description,
  url: canonicalURL.href,
  image: ogImageURL.href,
  inLanguage: 'zh-CN',
  isPartOf: {
    '@type': 'WebSite',
    name: siteConfig.name,
    url: siteURL.href,
  },
};
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <link rel="icon" href={siteConfig.favicon} type="image/svg+xml" />
    {siteConfig.fonts.stylesheets.map((href) => (
      <link rel="stylesheet" href={href} />
    ))}
    <style is:inline set:html={fontVariables}></style>
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      const savedTheme = localStorage.getItem('mjie-theme');
      const initialTheme = ['light', 'dark', 'auto'].includes(savedTheme) ? savedTheme : 'light';
      document.documentElement.dataset.theme = initialTheme;
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <Header current={current} hasSidebar={hasSidebar} />
    <slot />
    <footer class="site-footer">
      <p>
        {siteConfig.footerSource.prefix}
        <a href={siteConfig.footerSource.href} target="_blank" rel="noreferrer">{siteConfig.footerSource.linkLabel}</a>
        {siteConfig.footerSource.suffix}
      </p>
      {siteConfig.footerLinks.length > 0 && (
        <nav aria-label="页脚链接">
          {siteConfig.footerLinks.map((link) => (
            <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>{link.label}</a>
          ))}
        </nav>
      )}
      <small>
        © {siteConfig.copyright.year}{' '}
        <a href={siteConfig.copyright.href} target="_blank" rel="noreferrer">{siteConfig.copyright.owner}</a>.
        {' '}{siteConfig.copyright.text}
      </small>
    </footer>
    <SearchDialog lessons={lessons} />
    <script>
      const themeButton = document.querySelector('[data-theme-toggle]');
      const ORDER = ['light', 'dark', 'auto'];
      const LABEL = { light: '浅色', dark: '深色', auto: '跟随系统' };
      const isTheme = (value) => ORDER.includes(value);
      const updateThemeButton = () => {
        if (!themeButton) return;
        const root = document.documentElement;
        const stored = localStorage.getItem('mjie-theme');
        const state = isTheme(stored) ? stored : isTheme(root.dataset.theme) ? root.dataset.theme : 'light';
        root.dataset.theme = state;
        themeButton.setAttribute('data-theme-state', state);
        themeButton.setAttribute('aria-label', `切换主题（当前：${LABEL[state]}）`);
        themeButton.setAttribute('aria-pressed', state === 'auto' ? 'mixed' : String(state === 'dark'));
      };
      updateThemeButton();
      themeButton?.addEventListener('click', () => {
        const root = document.documentElement;
        const stored = localStorage.getItem('mjie-theme');
        const state = isTheme(stored) ? stored : isTheme(root.dataset.theme) ? root.dataset.theme : 'light';
        const idx = ORDER.indexOf(state);
        const next = ORDER[(idx + 1) % ORDER.length];
        root.dataset.theme = next;
        localStorage.setItem('mjie-theme', next);
        updateThemeButton();
      });
    </script>
  </body>
</html>
