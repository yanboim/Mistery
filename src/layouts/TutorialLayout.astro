---
import BaseLayout from './BaseLayout.astro';
import { chapters } from '../data/chapters';
import { getSourceEditURL, withSiteTitle } from '../site.config';

const { lesson, lessons, headings = [], previous, next } = Astro.props;
const currentChapter = chapters.find((chapter) => chapter.number === lesson.data.chapter);
const chapterLessons = lessons.filter((item) => item.data.chapter === lesson.data.chapter);
const currentIndex = chapterLessons.findIndex((item) => item.id === lesson.id);
const progress = Math.round(((currentIndex + 1) / chapterLessons.length) * 100);
const readingMinutes = Math.max(1, Math.ceil(lesson.body.replace(/\s/g, '').length / 350));
const tocHeadings = headings.filter((heading) => heading.depth <= 4);
const hasToc = tocHeadings.length > 0;
const editURL = getSourceEditURL(lesson.id);
---

<BaseLayout
  title={withSiteTitle(lesson.data.title)}
  description={lesson.data.description}
  current="tutorial"
  lessons={lessons}
  hasSidebar={true}
  schemaType="Article"
>
  <div class="reading-progress" aria-hidden="true"></div>
  <div class="tutorial-shell">
    <button class="sidebar-scrim" type="button" data-sidebar-close aria-label="关闭章节导航"></button>
    <aside class="lesson-sidebar" data-sidebar>
      <div class="sidebar-head">
        <strong>教程目录</strong>
        <button class="sidebar-close mobile-only" type="button" data-sidebar-close aria-label="关闭章节导航">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <nav aria-label="教程章节">
        {chapters.map((chapter) => {
          const items = lessons.filter((item) => item.data.chapter === chapter.number);
          return (
            <details open={chapter.number === lesson.data.chapter}>
              <summary>
                <span>{chapter.role}</span>
                <strong>{chapter.title}</strong>
                <small>{items.length}</small>
              </summary>
              <ol>
                {items.map((item) => (
                  <li>
                    <a class:list={{ active: item.id === lesson.id }} href={`/tutorial/${item.id}`}>
                      <span>{String(item.data.chapterOrder).padStart(2, '0')}</span>
                      {item.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          );
        })}
      </nav>
    </aside>

    <main class:list={["lesson-main", { "without-toc": !hasToc }]} id="main-content" data-lesson-id={lesson.id}>
      <article>
        <header class="lesson-head">
          <a class="chapter-link" href={`/tutorial/chapter-${lesson.data.chapter}`}>第{currentChapter?.numeral}章 / {lesson.data.chapterTitle}</a>
          <h1>{lesson.data.title}</h1>
          <div class="lesson-meta">
            <span>本章第 {lesson.data.chapterOrder} 节</span>
            <span>本章位置 {progress}%</span>
            <span>阅读约 {readingMinutes} 分钟</span>
            <a class="source-edit-link" href={editURL} target="_blank" rel="noreferrer">编辑本文</a>
            <button type="button" data-complete-toggle aria-pressed="false">标记已读</button>
          </div>
          <div class="chapter-progress" aria-label={`本章学习进度 ${progress}%`}>
            <span>{currentChapter?.role}</span>
            <div>
              <small>当前章节进度</small>
              <i style={`--chapter-progress:${progress}%`}></i>
            </div>
            <strong>{progress}%</strong>
          </div>
        </header>
        <div class="prose heti" data-typography="heti">
          <slot />
        </div>
        <nav class="lesson-pager" aria-label="相邻教程">
          {previous ? (
            <a href={`/tutorial/${previous.id}`}>
              <small>上一篇</small>
              <strong>{previous.data.title}</strong>
            </a>
          ) : <span></span>}
          {next && (
            <a class="next" href={`/tutorial/${next.id}`}>
              <small>下一篇</small>
              <strong>{next.data.title}</strong>
            </a>
          )}
        </nav>
      </article>

      {hasToc && (
        <aside class="page-toc" aria-label="本页目录">
          <strong>本页内容</strong>
          <nav>
            {tocHeadings.map((heading) => (
              <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  import Heti from 'heti/js/heti-addon.js';

  new Heti('.prose.heti').autoSpacing();

  const root = document.documentElement;
  const openSidebar = () => root.classList.add('sidebar-visible');
  const closeSidebar = () => root.classList.remove('sidebar-visible');
  document.querySelector('[data-sidebar-open]')?.addEventListener('click', openSidebar);
  document.querySelectorAll('[data-sidebar-close]').forEach((button) => button.addEventListener('click', closeSidebar));
  const lessonMain = document.querySelector('[data-lesson-id]');
  const lessonId = lessonMain?.getAttribute('data-lesson-id');
  const completeButton = document.querySelector('[data-complete-toggle]');
  const getCompleted = () => {
    try { return JSON.parse(localStorage.getItem('mjie-completed-lessons') || '[]'); }
    catch { return []; }
  };
  if (lessonId) {
    localStorage.setItem('mjie-last-lesson', lessonId);
    const updateCompleteButton = () => {
      const completed = getCompleted().includes(lessonId);
      completeButton?.setAttribute('aria-pressed', String(completed));
      if (completeButton) completeButton.textContent = completed ? '已读 · 取消' : '标记已读';
    };
    updateCompleteButton();
    completeButton?.addEventListener('click', () => {
      const completed = getCompleted();
      const nextCompleted = completed.includes(lessonId) ? completed.filter((id) => id !== lessonId) : [...completed, lessonId];
      localStorage.setItem('mjie-completed-lessons', JSON.stringify(nextCompleted));
      updateCompleteButton();
    });
  }
  requestAnimationFrame(() => {
    document.querySelector('.lesson-sidebar a.active')?.scrollIntoView({ block: 'center' });
  });
  const progressBar = document.querySelector('.reading-progress');
  const article = document.querySelector('.lesson-main article');
  let progressFrame = 0;
  const updateReadingProgress = () => {
    progressFrame = 0;
    if (!article || !progressBar) return;
    const start = article.getBoundingClientRect().top + window.scrollY - 120;
    const distance = Math.max(1, article.offsetHeight - window.innerHeight + 180);
    const value = Math.min(1, Math.max(0, (window.scrollY - start) / distance));
    progressBar.style.setProperty('--reading-progress', String(value));
  };
  const requestProgressUpdate = () => {
    if (!progressFrame) progressFrame = requestAnimationFrame(updateReadingProgress);
  };
  updateReadingProgress();
  window.addEventListener('scroll', requestProgressUpdate, { passive: true });
  window.addEventListener('resize', requestProgressUpdate);

  document.querySelectorAll('.prose > p').forEach((paragraph, index) => {
    if (index === 0) paragraph.classList.add('prose-lead');
    if (/^第[一-龥]+、?[，、]/.test(paragraph.textContent?.trim() || '')) paragraph.classList.add('prose-point');
  });

  const tocLinks = [...document.querySelectorAll('.page-toc a')];
  if (tocLinks.length) {
    const byId = new Map(tocLinks.map((link) => [decodeURIComponent(link.getAttribute('href')?.slice(1) || ''), link]));
    const observer = new IntersectionObserver((entries) => {
      entries.filter((entry) => entry.isIntersecting).forEach((entry) => {
        tocLinks.forEach((link) => link.removeAttribute('aria-current'));
        byId.get(entry.target.id)?.setAttribute('aria-current', 'location');
      });
    }, { rootMargin: '-18% 0px -70% 0px' });
    byId.forEach((_, id) => { const heading = document.getElementById(id); if (heading) observer.observe(heading); });
  }
</script>

<style>
  .reading-progress { position: fixed; z-index: 40; top: var(--header-height); left: 0; width: 100%; height: 2px; background: var(--accent); transform: scaleX(var(--reading-progress, 0)); transform-origin: left; will-change: transform; }
  .tutorial-shell { width: min(1500px, 100%); margin: 0 auto; display: grid; grid-template-columns: 306px minmax(0, 1fr); }
  .lesson-sidebar { height: calc(100dvh - var(--header-height)); position: sticky; top: var(--header-height); display: flex; flex-direction: column; overflow: hidden; padding: 26px 18px 60px; border-right: 1px solid var(--line); background: color-mix(in srgb, var(--bg) 84%, var(--surface) 16%); scrollbar-width: thin; scrollbar-color: var(--line) transparent; }
  .sidebar-head { position: relative; display: flex; align-items: center; padding: 0 8px 15px; }
  .sidebar-head strong { font-size: 15px; font-weight: 750; letter-spacing: -0.01em; }
  .sidebar-close { display: none; }
  .sidebar-close .icon { width: 16px; height: 16px; }
  .sidebar-close.mobile-only { position: absolute; top: -6px; right: 2px; width: 32px; height: 32px; display: none; place-items: center; padding: 0; border: 1px solid color-mix(in srgb, var(--line) 92%, transparent); border-radius: 999px; background: color-mix(in srgb, var(--surface) 72%, transparent); color: var(--text-soft); cursor: pointer; transition: border-color .2s ease, background .2s ease, color .2s ease; }
  .sidebar-close.mobile-only:hover { border-color: color-mix(in srgb, var(--accent) 60%, var(--line)); background: var(--surface-raised); color: var(--accent-strong); }
  .lesson-sidebar nav { min-height: 0; overflow: auto; padding-right: 2px; scrollbar-width: thin; scrollbar-color: var(--line) transparent; }
  details { margin-bottom: 5px; }
  summary { min-height: 46px; display: grid; grid-template-columns: 30px 1fr auto; gap: 8px; align-items: center; padding: 7px 8px; border-radius: 8px; cursor: pointer; list-style: none; transition: background .2s ease, color .2s ease; }
  summary::-webkit-details-marker { display: none; }
  summary:hover { background: var(--surface); }
  details[open] summary { position: sticky; top: 0; z-index: 2; background: color-mix(in srgb, var(--bg) 86%, var(--surface) 14%); backdrop-filter: blur(10px); }
  summary > span { width: 26px; height: 26px; display: grid; place-items: center; border-bottom: 1px solid var(--accent); color: var(--accent-strong); font-size: 17px; line-height: 1; font-weight: 800; }
  summary strong { font-size: 13px; }
  summary small { color: var(--text-soft); font-size: 10px; }
  ol { list-style: none; margin: 4px 0 14px; padding: 0 0 0 14px; }
  li a { display: grid; grid-template-columns: 28px 1fr; gap: 6px; padding: 8px 9px; border-left: 1px solid var(--line); color: var(--text-soft); font-size: 12px; line-height: 1.45; transition: background .2s ease, color .2s ease, border-color .2s ease; }
  li a:hover { color: var(--text); background: color-mix(in srgb, var(--surface) 62%, transparent); }
  li a.active { border-left-color: var(--accent); background: var(--surface); color: var(--text); font-weight: 650; }
  li a span { color: var(--text-soft); font-family: var(--font-code); font-size: 9px; padding-top: 2px; }
  .lesson-main { min-width: 0; display: grid; grid-template-columns: minmax(0, 780px) 190px; gap: clamp(50px, 7vw, 104px); justify-content: center; padding: 76px clamp(30px, 5vw, 76px) 118px; }
  .lesson-main.without-toc { grid-template-columns: minmax(0, 780px); }
  .lesson-main article { min-width: 0; }
  .lesson-head { padding-bottom: 26px; border-bottom: 1px solid var(--line); }
  .chapter-link { color: var(--accent-strong); font-size: 13px; font-weight: 700; }
  .lesson-head h1 { max-width: 100%; margin: 14px 0 20px; font-size: clamp(30px, 3.25vw, 42px); line-height: 1.18; letter-spacing: -.035em; text-wrap: pretty; }
  .lesson-meta { display: flex; gap: 18px 24px; align-items: center; color: var(--text-soft); font-size: 12px; }
  .lesson-meta span { white-space: nowrap; }
  .source-edit-link { margin-left: auto; color: var(--accent-strong); border-bottom: 1px solid currentColor; transition: color .2s ease, transform .2s ease; }
  .lesson-meta button { padding: 0; border: 0; border-bottom: 1px solid currentColor; background: transparent; color: var(--accent-strong); cursor: pointer; font-size: 12px; transition: color .2s ease, transform .2s ease; }
  .source-edit-link:hover, .lesson-meta button:hover { color: var(--text); }
  .source-edit-link:active, .lesson-meta button:active { transform: translateY(1px); }
  .chapter-progress { margin-top: 22px; padding: 14px 0 0; display: grid; grid-template-columns: 38px minmax(0, 1fr) auto; gap: 14px; align-items: center; border-top: 1px solid color-mix(in srgb, var(--line) 64%, transparent); }
  .chapter-progress > span { color: var(--accent-strong); font-size: 28px; font-weight: 800; line-height: 1; }
  .chapter-progress div { display: grid; gap: 6px; }
  .chapter-progress small { color: var(--text-soft); font-size: 11px; }
  .chapter-progress i { width: 100%; height: 5px; overflow: hidden; border-radius: 999px; background: var(--line); }
  .chapter-progress i::before { content: ''; display: block; width: var(--chapter-progress); height: 100%; border-radius: inherit; background: var(--accent); }
  .chapter-progress strong { color: var(--text-soft); font-family: var(--font-code); font-size: 13px; font-variant-numeric: tabular-nums; }
  .prose.heti { max-width: none; padding-top: 28px; font-family: var(--font-body); font-size: 16.5px; line-height: 1.72; letter-spacing: .006em; overflow-wrap: anywhere; hyphens: manual; }
  .prose :global(p) { margin: 0 0 1em; text-wrap: pretty; }
  .prose :global(.prose-lead) { color: color-mix(in srgb, var(--text) 88%, var(--accent)); font-size: 1.03em; line-height: 1.75; }
  .prose :global(.prose-point) { margin-top: 1.35em; padding: 1px 0 1px 14px; border-left: 2px solid color-mix(in srgb, var(--accent) 72%, var(--line)); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) { scroll-margin-top: 92px; line-height: 1.32; letter-spacing: -.018em; }
  .prose :global(h2) { margin: 1.65em 0 .62em; padding-top: .1em; border-top: 1px solid color-mix(in srgb, var(--line) 68%, transparent); font-size: 24px; letter-spacing: -.028em; }
  .prose :global(h3) { margin: 1.45em 0 .52em; font-size: 19px; }
  .prose :global(h4) { margin: 1.35em 0 .48em; font-size: 16px; color: var(--accent-strong); }
  .prose :global(strong) { color: var(--text); font-weight: 750; }
  .prose :global(a) { color: var(--accent-strong); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(blockquote) { margin: 1.25em 0; padding: 14px 18px; border-left: 3px solid var(--accent); background: var(--surface); color: var(--text-soft); border-radius: 0 8px 8px 0; }
  .prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .prose :global(ul), .prose :global(ol) { margin: 1em 0; padding-left: 1.4em; }
  .prose :global(li) { margin: .32em 0; padding-left: .25em; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 1.8em 0; }
  .prose :global(code) { padding: .15em .4em; border-radius: 5px; background: var(--code); font-family: var(--font-code); font-size: .9em; }
  .prose :global(img) { display: block; max-width: 82%; max-height: 72vh; width: auto; height: auto; margin: 1.8em auto; border-radius: 10px; border: 1px solid var(--line); }
  .prose :global(table) { width: 100%; display: block; overflow-x: auto; border-collapse: collapse; margin: 1.45em 0; }
  .prose :global(th), .prose :global(td) { padding: 10px 13px; border-bottom: 1px solid var(--line); text-align: left; }
  .lesson-pager { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-top: 42px; padding-top: 18px; border-top: 1px solid var(--line); background: transparent; }
  .lesson-pager a { min-height: 72px; display: flex; flex-direction: column; justify-content: center; padding: 14px 18px; border-bottom: 1px solid var(--line); background: var(--bg); transition: background .2s ease, color .2s ease, transform .2s ease; }
  .lesson-pager a:not(.next) { border-right: 1px solid var(--line); }
  .lesson-pager a.next { border-left: 1px solid var(--line); }
  .lesson-pager a:hover { background: var(--surface); color: var(--accent-strong); transform: translateY(-2px); }
  .lesson-pager a.next { text-align: right; }
  .lesson-pager small { color: var(--accent-strong); margin-bottom: 3px; font-size: 11px; }
  .lesson-pager strong { font-size: 13px; line-height: 1.42; }
  .page-toc { position: sticky; top: 100px; align-self: start; max-height: calc(100dvh - 130px); overflow: auto; padding-left: 16px; border-left: 1px solid var(--line); }
  .page-toc > strong { display: block; margin-bottom: 13px; font-size: 12px; }
  .page-toc nav { display: grid; gap: 9px; }
  .page-toc a { color: var(--text-soft); font-size: 11px; line-height: 1.55; transition: color .2s ease; }
  .page-toc a:hover { color: var(--accent-strong); }
  .page-toc a[aria-current='location'] { color: var(--accent-strong); font-weight: 650; }
  .page-toc .depth-4 { padding-left: 10px; }
  .sidebar-scrim { display: none; }
  @media (max-width: 1120px) {
    .lesson-main { grid-template-columns: minmax(0, 760px); }
    .page-toc { display: none; }
  }
  @media (max-width: 820px) {
    .tutorial-shell { display: block; }
    .lesson-sidebar { position: fixed; z-index: 60; inset: 0 auto 0 0; width: min(330px, 88vw); height: 100dvh; background: var(--bg); transform: translateX(-102%); transition: transform .25s ease; }
    .sidebar-close.mobile-only { display: inline-grid !important; }
    .sidebar-scrim { position: fixed; z-index: 50; inset: 0; width: 100%; height: 100%; border: 0; background: rgba(2, 5, 9, .7); opacity: 0; pointer-events: none; transition: opacity .25s ease; }
    :global(.sidebar-visible) .lesson-sidebar { transform: translateX(0); }
    :global(.sidebar-visible) .sidebar-scrim { display: block; opacity: 1; pointer-events: auto; }
    .lesson-main { display: block; padding: 50px 20px 84px; }
  }
  @media (max-width: 560px) {
    .lesson-head h1 { font-size: 29px; line-height: 1.2; }
    .prose.heti { padding-top: 24px; font-size: 16px; line-height: 1.7; }
    .prose :global(h2) { font-size: 22px; }
    .prose :global(h3) { font-size: 18px; }
    .chapter-progress { grid-template-columns: 36px minmax(0, 1fr) auto; gap: 12px; }
    .chapter-progress > span { font-size: 28px; }
    .lesson-pager { grid-template-columns: 1fr; }
    .lesson-pager > span { display: none; }
    .lesson-pager a.next { text-align: left; }
    .lesson-meta { flex-wrap: wrap; gap: 8px 16px; }
    .source-edit-link { margin-left: 0; }
    .lesson-meta button { width: 100%; margin: 5px 0 0; min-height: 40px; border: 1px solid var(--line); border-radius: 7px; }
  }
</style>
