---
import BaseLayout from './BaseLayout.astro';
import { chapters } from '../data/chapters';

const { lesson, lessons, headings = [], previous, next } = Astro.props;
const currentChapter = chapters.find((chapter) => chapter.number === lesson.data.chapter);
const chapterLessons = lessons.filter((item) => item.data.chapter === lesson.data.chapter);
const currentIndex = chapterLessons.findIndex((item) => item.id === lesson.id);
const progress = Math.round(((currentIndex + 1) / chapterLessons.length) * 100);
const readingMinutes = Math.max(1, Math.ceil(lesson.body.replace(/\s/g, '').length / 350));
const tocHeadings = headings.filter((heading) => heading.depth <= 4);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout
  title={`${lesson.data.title} | M姐交易笔记`}
  description={lesson.data.description}
  current="tutorial"
  lessons={lessons}
  hasSidebar={true}
>
  <div class="reading-progress" aria-hidden="true"></div>
  <div class="tutorial-shell">
    <button class="sidebar-scrim" type="button" data-sidebar-close aria-label="关闭章节导航"></button>
    <aside class="lesson-sidebar" data-sidebar>
      <div class="sidebar-head">
        <strong>教程目录</strong>
        <button class="quiet-button mobile-only" type="button" data-sidebar-close>关闭</button>
      </div>
      <button class="sidebar-search" type="button" data-search-open>搜索全部教程</button>
      <nav aria-label="教程章节">
        {chapters.map((chapter) => {
          const items = lessons.filter((item) => item.data.chapter === chapter.number);
          return (
            <details open={chapter.number === lesson.data.chapter}>
              <summary>
                <span>{chapter.role}</span>
                <strong>{chapter.title}</strong>
                <small>{items.length}</small>
              </summary>
              <ol>
                {items.map((item) => (
                  <li>
                    <a class:list={{ active: item.id === lesson.id }} href={`/tutorial/${item.id}`}>
                      <span>{String(item.data.chapterOrder).padStart(2, '0')}</span>
                      {item.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          );
        })}
      </nav>
    </aside>

    <main class:list={["lesson-main", { "without-toc": !hasToc }]} id="main-content" data-lesson-id={lesson.id}>
      <article>
        <header class="lesson-head">
          <a class="chapter-link" href={`/tutorial#chapter-${lesson.data.chapter}`}>第{currentChapter?.numeral}章 / {lesson.data.chapterTitle}</a>
          <h1>{lesson.data.title}</h1>
          <div class="lesson-meta">
            <span>本章第 {lesson.data.chapterOrder} 节</span>
            <span>本章位置 {progress}%</span>
            <span>阅读约 {readingMinutes} 分钟</span>
            <button type="button" data-complete-toggle aria-pressed="false">标记已读</button>
          </div>
        </header>
        <div class="prose">
          <slot />
        </div>
        <nav class="lesson-pager" aria-label="相邻教程">
          {previous ? (
            <a href={`/tutorial/${previous.id}`}>
              <small>上一篇</small>
              <strong>{previous.data.title}</strong>
            </a>
          ) : <span></span>}
          {next && (
            <a class="next" href={`/tutorial/${next.id}`}>
              <small>下一篇</small>
              <strong>{next.data.title}</strong>
            </a>
          )}
        </nav>
      </article>

      {hasToc && (
        <aside class="page-toc" aria-label="本页目录">
          <strong>本页内容</strong>
          <nav>
            {tocHeadings.map((heading) => (
              <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  const root = document.documentElement;
  const openSidebar = () => root.classList.add('sidebar-visible');
  const closeSidebar = () => root.classList.remove('sidebar-visible');
  document.querySelector('[data-sidebar-open]')?.addEventListener('click', openSidebar);
  document.querySelectorAll('[data-sidebar-close]').forEach((button) => button.addEventListener('click', closeSidebar));
  const lessonMain = document.querySelector('[data-lesson-id]');
  const lessonId = lessonMain?.getAttribute('data-lesson-id');
  const completeButton = document.querySelector('[data-complete-toggle]');
  const getCompleted = () => {
    try { return JSON.parse(localStorage.getItem('mjie-completed-lessons') || '[]'); }
    catch { return []; }
  };
  if (lessonId) {
    localStorage.setItem('mjie-last-lesson', lessonId);
    const updateCompleteButton = () => {
      const completed = getCompleted().includes(lessonId);
      completeButton?.setAttribute('aria-pressed', String(completed));
      if (completeButton) completeButton.textContent = completed ? '已读 · 取消' : '标记已读';
    };
    updateCompleteButton();
    completeButton?.addEventListener('click', () => {
      const completed = getCompleted();
      const nextCompleted = completed.includes(lessonId) ? completed.filter((id) => id !== lessonId) : [...completed, lessonId];
      localStorage.setItem('mjie-completed-lessons', JSON.stringify(nextCompleted));
      updateCompleteButton();
    });
  }
  requestAnimationFrame(() => document.querySelector('.lesson-sidebar a.active')?.scrollIntoView({ block: 'center' }));
  const progressBar = document.querySelector('.reading-progress');
  const article = document.querySelector('.lesson-main article');
  let progressFrame = 0;
  const updateReadingProgress = () => {
    progressFrame = 0;
    if (!article || !progressBar) return;
    const start = article.getBoundingClientRect().top + window.scrollY - 120;
    const distance = Math.max(1, article.offsetHeight - window.innerHeight + 180);
    const value = Math.min(1, Math.max(0, (window.scrollY - start) / distance));
    progressBar.style.setProperty('--reading-progress', String(value));
  };
  const requestProgressUpdate = () => {
    if (!progressFrame) progressFrame = requestAnimationFrame(updateReadingProgress);
  };
  updateReadingProgress();
  window.addEventListener('scroll', requestProgressUpdate, { passive: true });
  window.addEventListener('resize', requestProgressUpdate);

  document.querySelectorAll('.prose > p').forEach((paragraph, index) => {
    if (index === 0) paragraph.classList.add('prose-lead');
    if (/^第[一-龥]+、?[，、]/.test(paragraph.textContent?.trim() || '')) paragraph.classList.add('prose-point');
  });

  const tocLinks = [...document.querySelectorAll('.page-toc a')];
  if (tocLinks.length) {
    const byId = new Map(tocLinks.map((link) => [decodeURIComponent(link.getAttribute('href')?.slice(1) || ''), link]));
    const observer = new IntersectionObserver((entries) => {
      entries.filter((entry) => entry.isIntersecting).forEach((entry) => {
        tocLinks.forEach((link) => link.removeAttribute('aria-current'));
        byId.get(entry.target.id)?.setAttribute('aria-current', 'location');
      });
    }, { rootMargin: '-18% 0px -70% 0px' });
    byId.forEach((_, id) => { const heading = document.getElementById(id); if (heading) observer.observe(heading); });
  }
</script>

<style>
  .reading-progress { position: fixed; z-index: 40; top: var(--header-height); left: 0; width: 100%; height: 2px; background: var(--accent); transform: scaleX(var(--reading-progress, 0)); transform-origin: left; will-change: transform; }
  .tutorial-shell { width: min(1480px, 100%); margin: 0 auto; display: grid; grid-template-columns: 292px minmax(0, 1fr); }
  .lesson-sidebar { height: calc(100dvh - var(--header-height)); position: sticky; top: var(--header-height); overflow: auto; padding: 24px 18px 60px; border-right: 1px solid var(--line); scrollbar-width: thin; scrollbar-color: var(--line) transparent; }
  .sidebar-head { display: flex; align-items: center; justify-content: space-between; padding: 0 8px 15px; }
  .sidebar-head strong { font-size: 13px; }
  .sidebar-search { width: 100%; margin-bottom: 16px; padding: 9px 10px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); color: var(--text-soft); text-align: left; cursor: pointer; font-size: 13px; }
  details { margin-bottom: 5px; }
  summary { min-height: 44px; display: grid; grid-template-columns: 28px 1fr auto; gap: 8px; align-items: center; padding: 7px 8px; border-radius: 8px; cursor: pointer; list-style: none; }
  summary::-webkit-details-marker { display: none; }
  summary:hover { background: var(--surface); }
  summary > span { width: 25px; height: 25px; display: grid; place-items: center; border: 1px solid var(--line); border-radius: 50%; color: var(--accent-strong); font-size: 12px; }
  summary strong { font-size: 13px; }
  summary small { color: var(--text-soft); font-size: 10px; }
  ol { list-style: none; margin: 4px 0 14px; padding: 0 0 0 14px; }
  li a { display: grid; grid-template-columns: 27px 1fr; gap: 6px; padding: 7px 9px; border-left: 1px solid var(--line); color: var(--text-soft); font-size: 12px; line-height: 1.45; }
  li a:hover { color: var(--text); }
  li a.active { border-left-color: var(--accent); background: var(--surface); color: var(--text); font-weight: 650; }
  li a span { color: var(--text-soft); font-family: ui-monospace, monospace; font-size: 9px; padding-top: 2px; }
  .lesson-main { min-width: 0; display: grid; grid-template-columns: minmax(0, 760px) 180px; gap: clamp(46px, 6vw, 90px); justify-content: center; padding: 68px clamp(30px, 5vw, 72px) 110px; }
  .lesson-main.without-toc { grid-template-columns: minmax(0, 760px); }
  .lesson-main article { min-width: 0; }
  .lesson-head { padding-bottom: 35px; border-bottom: 1px solid var(--line); }
  .chapter-link { color: var(--accent-strong); font-size: 13px; font-weight: 700; }
  .lesson-head h1 { margin: 18px 0 22px; font-size: clamp(34px, 4.5vw, 56px); line-height: 1.18; letter-spacing: -.04em; text-wrap: balance; }
  .lesson-meta { display: flex; gap: 24px; color: var(--text-soft); font-size: 12px; }
  .lesson-meta button { margin-left: auto; padding: 0; border: 0; border-bottom: 1px solid currentColor; background: transparent; color: var(--accent-strong); cursor: pointer; font-size: 12px; }
  .prose { padding-top: 40px; font-size: 16px; line-height: 2; overflow-wrap: anywhere; }
  .prose :global(p) { margin: 0 0 1.55em; text-wrap: pretty; }
  .prose :global(.prose-lead) { color: color-mix(in srgb, var(--text) 88%, var(--accent)); font-size: 1.06em; }
  .prose :global(.prose-point) { margin-top: 2.15em; padding-left: 18px; border-left: 2px solid color-mix(in srgb, var(--accent) 72%, var(--line)); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) { scroll-margin-top: 92px; line-height: 1.35; letter-spacing: -.02em; }
  .prose :global(h2) { margin: 2.5em 0 .9em; font-size: 27px; }
  .prose :global(h3) { margin: 2.2em 0 .8em; font-size: 21px; }
  .prose :global(h4) { margin: 2em 0 .7em; font-size: 17px; color: var(--accent-strong); }
  .prose :global(strong) { color: var(--text); font-weight: 750; }
  .prose :global(a) { color: var(--accent-strong); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(blockquote) { margin: 2em 0; padding: 20px 24px; border-left: 3px solid var(--accent); background: var(--surface); color: var(--text-soft); border-radius: 0 8px 8px 0; }
  .prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .prose :global(ul), .prose :global(ol) { margin: 1.4em 0; padding-left: 1.4em; }
  .prose :global(li) { margin: .55em 0; padding-left: .3em; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 3em 0; }
  .prose :global(code) { padding: .15em .4em; border-radius: 5px; background: var(--code); font-family: ui-monospace, monospace; font-size: .9em; }
  .prose :global(table) { width: 100%; display: block; overflow-x: auto; border-collapse: collapse; margin: 2em 0; }
  .prose :global(th), .prose :global(td) { padding: 10px 13px; border-bottom: 1px solid var(--line); text-align: left; }
  .lesson-pager { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 70px; padding-top: 28px; border-top: 1px solid var(--line); }
  .lesson-pager a { min-height: 112px; display: flex; flex-direction: column; justify-content: center; padding: 18px 20px; border: 1px solid var(--line); border-radius: 9px; background: var(--surface); transition: border-color .2s ease, transform .2s ease; }
  .lesson-pager a:hover { border-color: var(--accent); transform: translateY(-2px); }
  .lesson-pager a.next { text-align: right; }
  .lesson-pager small { color: var(--accent-strong); margin-bottom: 5px; }
  .lesson-pager strong { font-size: 14px; line-height: 1.5; }
  .page-toc { position: sticky; top: 100px; align-self: start; max-height: calc(100dvh - 130px); overflow: auto; }
  .page-toc > strong { display: block; margin-bottom: 12px; font-size: 12px; }
  .page-toc nav { display: grid; gap: 8px; }
  .page-toc a { color: var(--text-soft); font-size: 11px; line-height: 1.5; }
  .page-toc a:hover { color: var(--accent-strong); }
  .page-toc a[aria-current='location'] { color: var(--accent-strong); font-weight: 650; }
  .page-toc .depth-4 { padding-left: 10px; }
  .sidebar-scrim { display: none; }
  @media (max-width: 1120px) {
    .lesson-main { grid-template-columns: minmax(0, 760px); }
    .page-toc { display: none; }
  }
  @media (max-width: 820px) {
    .tutorial-shell { display: block; }
    .lesson-sidebar { position: fixed; z-index: 60; inset: 0 auto 0 0; width: min(330px, 88vw); height: 100dvh; background: var(--bg); transform: translateX(-102%); transition: transform .25s ease; }
    .sidebar-scrim { position: fixed; z-index: 50; inset: 0; width: 100%; height: 100%; border: 0; background: rgba(2, 5, 9, .7); opacity: 0; pointer-events: none; transition: opacity .25s ease; }
    :global(.sidebar-visible) .lesson-sidebar { transform: translateX(0); }
    :global(.sidebar-visible) .sidebar-scrim { display: block; opacity: 1; pointer-events: auto; }
    .lesson-main { display: block; padding: 44px 20px 80px; }
  }
  @media (max-width: 560px) {
    .lesson-head h1 { font-size: 36px; }
    .lesson-pager { grid-template-columns: 1fr; }
    .lesson-pager > span { display: none; }
    .lesson-pager a.next { text-align: left; }
    .lesson-meta { flex-wrap: wrap; gap: 8px 16px; }
    .lesson-meta button { width: 100%; margin: 5px 0 0; min-height: 40px; border: 1px solid var(--line); border-radius: 7px; }
  }
</style>
